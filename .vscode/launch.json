{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Payload Dev",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"],
			"env": {
				"NODE_ENV": "development"
			},
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Debug Payload with Inspector",
			"type": "node",
			"request": "attach",
			"port": 9230, // ← Исправлено! У вас debugger port: 9230
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"],
			"restart": true,
			"timeout": 30000
		},
		{
			"name": "Debug Chrome - Frontend",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:3001", // ← Исправлено! У вас порт 3001
			"webRoot": "${workspaceFolder}",
			"skipFiles": ["**/node_modules/**"],
			"sourceMapPathOverrides": {
				"webpack:///./*": "${webRoot}/*"
			}
		},
		{
			"name": "Attach to Chrome",
			"type": "chrome",
			"request": "attach",
			"port": 9222,
			"webRoot": "${workspaceFolder}"
		}
	],
	"compounds": [
		{
			"name": "Full Stack Debug (Backend + Frontend)",
			"configurations": ["Debug Payload with Inspector", "Debug Chrome - Frontend"]
		}
	]
}
